						<h6 class="fw-bold mb-1">Dra. Laura Méndez</h6>
						<p class="text-primary small mb-0">Odontología General</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="py-5 bg-primary text-white">

	<div class="text-center mb-5">
		<h2 class="fw-bold text-white">¿Cómo reservar tu turno?</h2>
		<p class="opacity-75">Sigue estos tres sencillos pasos</p>
	</div>
	<div class="row g-4 text-center">
		<div class="col-md-4">
			<div class="step-number">1</div>
			<h5 class="fw-bold">Elige tu Servicio</h5>
			<p class="opacity-75">Selecciona el tratamiento que necesitas de nuestra lista de servicios.</p>
		</div>
		<div class="col-md-4">
			<div class="step-number">2</div>
			<h5 class="fw-bold">Selecciona Fecha</h5>
			<p class="opacity-75">Busca en nuestro calendario el día y la hora que mejor te convenga.</p>
		</div>
		<div class="col-md-4">
			<div class="step-number">3</div>
			<h5 class="fw-bold">Confirma y Asiste</h5>
			<p class="opacity-75">Recibirás un recordatorio por correo. ¡Te esperamos en la clínica!</p>
		</div>
		<div class="d-grid d-md-flex gap-3 justify-content-center">
			<button class="btn btn-primary btn-lg px-5">Reservar Turno</button>
		</div>
	</div>

</section>
