					<div class="card-body text-center">
						<h6 class="fw-bold mb-1">Dr. Carlos Sosa</h6>
						<p class="text-primary small mb-0">Cirujano Implantólogo</p>
					</div>
				</div>
			</div>
			<div class="col-md-4 col-lg-3">
