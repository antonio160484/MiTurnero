@{
	ViewData["Title"] = "Home Page";
}

<header class="hero-section" id="inicio">
	<div class="container">
		<div class="row align-items-center g-5">
			<div class="col-lg-6">
				<h1 class="display-4 fw-black mb-4">Tu Sonrisa, Nuestra Prioridad</h1>
				<p class="lead text-muted-custom mb-5">Ofrecemos servicios dentales de alta calidad con la mejor tecnología para cuidar de tu salud bucal. Tu bienestar comienza con una sonrisa sana.</p>
				<div class="d-grid d-md-flex gap-3">
					<button class="btn btn-primary btn-lg px-5">Reservar Turno</button>
					<button class="btn btn-outline-primary btn-lg px-5">Ver Servicios</button>
				</div>
			</div>
			<div class="col-lg-6">
				<img alt="Modern Dental Office" class="img-fluid rounded-xl shadow-lg" data-alt="Modern and bright dental clinic office interior" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC2B_G5lCnhP-IXWxzarywiHG2kOLL2KNdWniw7tjrZPzGrdYyRhXxwIWjHsagYWKhC95dLeMAVGrTUC4tYmJo09ZbqDE898yYpcbMs5lwelpRu6BFRC4jqJyHYdYrdpGMtRwvQrkR4w9SJmSRKPPZT2U1wewWFEAy3EeTOFsm4XPJMT6kMGTK_xY2orxN7q7E5uCRxCH0u6g2q_LW5cRIByz1ZgB7OfZdvRytGo2bE48jGQgwW0rF1-6LrenPso8g0iC70weOa4Aau" />
			</div>
		</div>
	</div>
</header>

<section class="py-5 bg-light" id="servicios">
	<div class="container py-5">
		<div class="text-center mb-5">
			<h2 class="fw-bold">Nuestros Servicios</h2>
			<p class="text-muted-custom">Soluciones integrales para toda la familia</p>
		</div>
		<div class="row g-4">
			<div class="col-md-4">
				<div class="card h-100 p-4 text-center">
					<div class="card-body">
						<span class="material-symbols-outlined service-icon">cleaning_services</span>
						<h5 class="card-title fw-bold">Limpieza Dental</h5>
						<p class="card-text text-muted-custom">Mantén tus dientes sanos y brillantes con nuestras limpiezas profundas.</p>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card h-100 p-4 text-center">
					<div class="card-body">
						<span class="material-symbols-outlined service-icon">orthopedics</span>
						<h5 class="card-title fw-bold">Ortodoncia</h5>
						<p class="card-text text-muted-custom">Alineación perfecta para una sonrisa funcional y estética para niños y adultos.</p>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card h-100 p-4 text-center">
					<div class="card-body">
						<span class="material-symbols-outlined service-icon">masks</span>
						<h5 class="card-title fw-bold">Implantes</h5>
						<p class="card-text text-muted-custom">Soluciones duraderas y naturales para piezas faltantes con la mejor tecnología.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

